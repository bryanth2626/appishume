<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/main"
  android:orientation="vertical"
  android:background="#FFFFFF"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".Calendario">

  <TextView
    android:text="Calendario de Eventos"
    android:textSize="22sp"
    android:textStyle="bold"
    android:textColor="#FF6F00"
    android:textAlignment="center"
    android:paddingTop="20dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" />

  <CalendarView
    android:id="@+id/calendarView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" />

  <TextView
    android:id="@+id/tvFechaSeleccionada"
    android:text="Eventos del día"
    android:textSize="16sp"
    android:textStyle="bold"
    android:textColor="#FF8F00"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="4dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" />

  <TextView
    android:id="@+id/tvSinEventos"
    android:text="No hay eventos para este día"
    android:textSize="14sp"
    android:textColor="#999999"
    android:textAlignment="center"
    android:paddingTop="20dp"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" />

  <ListView
    android:id="@+id/lsvEventosDia"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:divider="#FFE0B2"
    android:dividerHeight="1dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />

</LinearLayout>
